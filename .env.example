# ── Infisical (recommended) ──────────────────────────────────────────
# Create a Machine Identity with Universal Auth and grant read access.
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
# Defaults — override if needed:
# INFISICAL_PROJECT_ID=7c539df3-0f68-42c8-91d9-b897e2a1cadf
# INFISICAL_ENVIRONMENT=prod
# INFISICAL_SECRET_PATH=/buxfer-mcp
# INFISICAL_URL=https://app.infisical.com

# ── OR: plain .env fallback ──────────────────────────────────────────
# If Infisical is not configured, fill in these values directly.
BUXFER_EMAIL=
BUXFER_PASSWORD=
